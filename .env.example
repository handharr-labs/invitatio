# ---------------------------------------------------------------------------
# invitatio — environment
# Copy to .env.local and fill in. The app RUNS without any of these set:
# the /[slug] read path falls back to an in-memory sample config so you can see
# a rendered invitation immediately. Fill these in to activate real auth + DB.
# ---------------------------------------------------------------------------

# --- NextAuth (admin login) -------------------------------------------------
# Base URL NextAuth uses to build the Google OAuth redirect_uri and the
# post-login redirect. Set this for local dev so login stays on localhost
# (without it, NextAuth infers the host and can bounce you to the prod URL).
# On Vercel, set NEXTAUTH_URL to the deployment URL in the project env instead.
NEXTAUTH_URL=http://localhost:3000

# DEV ONLY: skip the admin login guard so you can explore the dashboard before
# Google OAuth is set up. Leave blank / false in any deployed environment.
AUTH_DISABLED=false

# Generate: `openssl rand -base64 32`
AUTH_SECRET=

# Google OAuth client (Google Cloud Console -> Credentials -> OAuth 2.0 Client).
# Authorized redirect URI (local): http://localhost:3000/api/auth/callback/google
# NOT set up yet — leave blank until the Google client is created.
GOOGLE_ID=
GOOGLE_SECRET=

# Comma-separated allowlist of admin emails permitted to sign in.
# Leave blank in local dev to allow any Google account.
ADMIN_EMAILS=

# --- Supabase (Postgres + storage; auth is owned by NextAuth above) ---------
# Supabase Dashboard -> Project Settings -> API. Leave blank to use the
# in-memory sample-config fallback for the read path.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client. Used for admin writes / seeding.
SUPABASE_SERVICE_ROLE_KEY=
