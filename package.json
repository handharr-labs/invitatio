{
  "name": "invitatio",
  "version": "0.1.0",
  "private": true,
  "description": "Admin-scaffolded, per-couple published wedding invitation sites. Data + admin + routing layer on top of the @handharr-labs Forge Kit.",
  "scripts": {
    "dev": "next dev",
    "local-dev": "node scripts/link-kit.mjs && next dev --webpack",
    "kit:link": "node scripts/link-kit.mjs",
    "kit:unlink": "node scripts/link-kit.mjs --unlink",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "seed:emit": "node scripts/emit-seed.mjs"
  },
  "dependencies": {
    "@handharr-labs/forge-auth": "^0.2.1",
    "@handharr-labs/forge-core": "^0.6.0",
    "@handharr-labs/forge-ui-base-gold": "^0.11.0",
    "@handharr-labs/forge-ui-dos": "^0.3.1",
    "@handharr-labs/forge-web-server": "^0.4.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.5.0",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3"
  }
}
